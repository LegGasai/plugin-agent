# Copy this file to .env before running docker compose if you want to override defaults.

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Persist backend SQLite/secrets/memory under docker/volumes by default.
DOCKER_VOLUME_DIRECTORY=.

# The frontend is built to call Nginx on the same origin, which proxies to backend:8000.
VITE_PLUGIN_AGENT_API=/plugin-agent-api

# Container path for the local marketplace copied into the backend image.
PLUGIN_AGENT_MARKET_DIR=/app/plugin-market
