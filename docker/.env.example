# Copy this file to .env before running docker compose if you want to override defaults.

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Persist backend SQLite/secrets/memory under docker/volumes by default.
DOCKER_VOLUME_DIRECTORY=.

# The frontend is built to call Nginx on the same origin, which proxies to backend:8000.
VITE_PLUGIN_AGENT_API=/plugin-agent-api

# Container path for the local marketplace copied into the backend image.
PLUGIN_AGENT_MARKET_DIR=/app/plugin-market

# Optional model provider configuration. Leave blank unless you want env-level defaults.
# PLUGIN_AGENT_MODEL_API_KEY=
# PLUGIN_AGENT_MODEL_NAME=gpt-4o-mini
# PLUGIN_AGENT_MODEL_BASE_URL=https://api.openai.com/v1

# PLUGIN_AGENT_OPENROUTER_API_KEY=
# PLUGIN_AGENT_OPENROUTER_MODEL=openai/gpt-4o-mini
# PLUGIN_AGENT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PLUGIN_AGENT_DEEPSEEK_API_KEY=
# PLUGIN_AGENT_DEEPSEEK_MODEL=deepseek-v4-flash
# PLUGIN_AGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com
